POST        /change-refund-period                        controllers.RefundPeriodController.onSubmit(mode: Mode = CheckMode)

GET         /how-contact-you-about-claim               controllers.ContactDetailsController.onPageLoad(mode: Mode = NormalMode)
POST        /how-contact-you-about-claim                controllers.ContactDetailsController.onSubmit(mode: Mode = NormalMode)
GET         /change-how-contact-you-about-claim        controllers.ContactDetailsController.onPageLoad(mode: Mode = CheckMode)
POST        /change-how-contact-you-about-claim        controllers.ContactDetailsController.onSubmit(mode: Mode = CheckMode)

GET         /business-activity                           controllers.BusinessActivityController.onPageLoad(mode: Mode = NormalMode)
POST        /business-activity                           controllers.BusinessActivityController.onSubmit(mode: Mode = NormalMode)
