GET         /business-activity-3                         controllers.BusinessActivityThreeController.onPageLoad()
POST        /business-activity-3                         controllers.BusinessActivityThreeController.onSubmit()

GET         /check-your-claim-details                    controllers.CheckYourClaimDetailsController.onPageLoad()
POST        /check-your-claim-details                    controllers.CheckYourClaimDetailsController.onSubmit()

